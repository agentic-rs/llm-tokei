---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "llm-tokei",
  description = "Local usage reports for coding-agent sessions."
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`${import.meta.env.BASE_URL}showcase.svg`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f2ea" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonical.toString()} />
    <style is:global>
      :root {
        color-scheme: light;
        --paper: #f5f2ea;
        --paper-deep: #e9e1d1;
        --ink: #171717;
        --ink-soft: #4e514d;
        --ink-muted: #74786f;
        --line: #d5cab7;
        --line-strong: #b7a98f;
        --panel: #fffaf0;
        --panel-cool: #eef5f1;
        --code: #101418;
        --code-soft: #20272e;
        --green: #23735e;
        --green-deep: #15493c;
        --blue: #2d5d89;
        --amber: #9d5f16;
        --rust: #8d3326;
        --max-width: 1180px;
        --font-sans:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        --font-mono:
          "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-width: 320px;
        font-family: var(--font-sans);
        color: var(--ink);
        background:
          linear-gradient(90deg, rgba(23, 23, 23, 0.035) 1px, transparent 1px),
          linear-gradient(rgba(23, 23, 23, 0.035) 1px, transparent 1px),
          linear-gradient(180deg, var(--paper) 0%, #f8f6ef 48%, #efe7d9 100%);
        background-size: 44px 44px, 44px 44px, auto;
        line-height: 1.5;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      code,
      pre {
        font-family: var(--font-mono);
      }

      code {
        font-size: 0.95em;
      }

      main {
        padding: clamp(1.5rem, 4vw, 3rem) 0 clamp(3rem, 7vw, 5rem);
      }

      section {
        scroll-margin-top: 6rem;
      }

      .container {
        width: min(calc(100% - clamp(1rem, 5vw, 2rem)), var(--max-width));
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: rgba(245, 242, 234, 0.88);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(16px);
      }

      .site-header__inner,
      .site-footer__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .site-header__inner {
        min-height: 4.25rem;
        padding-block: 0.35rem;
      }

      .site-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        font-weight: 800;
        letter-spacing: 0;
      }

      .site-brand__mark {
        display: grid;
        width: 2rem;
        height: 2rem;
        place-items: center;
        border: 1px solid var(--ink);
        border-radius: 6px;
        color: var(--panel);
        background: var(--ink);
        font-family: var(--font-mono);
        font-size: 0.78rem;
      }

      .site-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.35rem;
        min-width: 0;
      }

      .site-nav a {
        padding: 0.45rem 0.65rem;
        border-radius: 6px;
        color: var(--ink-soft);
        font-size: 0.94rem;
        transition:
          background 160ms ease,
          color 160ms ease;
      }

      .site-nav a:hover {
        color: var(--ink);
        background: rgba(23, 23, 23, 0.07);
      }

      .site-footer {
        padding: 1.5rem 0 3rem;
      }

      .site-footer__inner {
        padding-top: 1.5rem;
        border-top: 1px solid var(--line);
      }

      .site-footer__copy {
        margin: 0;
        color: var(--ink-muted);
        font-size: 0.94rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        gap: 0.5rem;
        color: var(--green-deep);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 0.58rem;
        height: 0.58rem;
        border-radius: 2px;
        background: var(--green);
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.85rem;
        min-width: 0;
        padding: 0.75rem 1rem;
        border: 1px solid var(--ink);
        border-radius: 7px;
        font-weight: 800;
        line-height: 1;
        transition:
          transform 160ms ease,
          box-shadow 160ms ease,
          background 160ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
        box-shadow: 4px 4px 0 var(--ink);
      }

      .button--primary {
        color: var(--panel);
        background: var(--green-deep);
      }

      .button--secondary {
        color: var(--ink);
        background: var(--panel);
      }

      .button--quiet {
        border-color: var(--line-strong);
        color: var(--green-deep);
        background: transparent;
      }

      .panel {
        border: 1px solid var(--line-strong);
        border-radius: 8px;
        background: rgba(255, 250, 240, 0.86);
      }

      .section-title {
        margin: 0;
        max-width: 14ch;
        font-size: clamp(2rem, 4vw, 4.25rem);
        line-height: 0.96;
        letter-spacing: 0;
      }

      .section-copy {
        margin: 0;
        max-width: 44rem;
        color: var(--ink-soft);
        font-size: 1.02rem;
      }

      .mono {
        font-family: var(--font-mono);
      }

      @media (max-width: 820px) {
        .site-header__inner {
          align-items: center;
          flex-wrap: wrap;
          gap: 0.55rem 1rem;
          padding-block: 0.7rem;
        }

        .site-footer__inner {
          align-items: flex-start;
          flex-direction: column;
        }

        .site-nav {
          flex-wrap: nowrap;
          justify-content: flex-start;
          max-width: 100%;
          overflow-x: auto;
          scrollbar-width: none;
          -webkit-overflow-scrolling: touch;
        }

        .site-nav::-webkit-scrollbar {
          display: none;
        }

        .site-header .site-nav {
          width: 100%;
        }

        .site-nav a {
          flex: 0 0 auto;
        }
      }

      @media (max-width: 560px) {
        .button {
          width: 100%;
        }

        .button-row {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="site-brand" href="#top" aria-label="llm-tokei home">
          <span class="site-brand__mark">lt</span>
          <span>llm-tokei</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href="#why">Why</a>
          <a href="#sources">Sources</a>
          <a href="#recipes">Recipes</a>
          <a href="https://github.com/agentic-rs/llm-tokei">GitHub</a>
          <a href="https://docs.rs/llm-tokei">docs.rs</a>
        </nav>
      </div>
    </header>
    <main id="top">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container site-footer__inner">
        <p class="site-footer__copy">
          Built for local reports from local coding-agent session files.
        </p>
        <nav class="site-nav" aria-label="Footer">
          <a href="https://crates.io/crates/llm-tokei">crates.io</a>
          <a href="https://github.com/agentic-rs/llm-tokei/blob/main/docs/usage.md">Usage</a>
          <a href="https://github.com/agentic-rs/llm-tokei">Source</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
