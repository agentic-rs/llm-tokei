---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "llm-tokei",
  description = "See where your local coding-agent tokens went."
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`${import.meta.env.BASE_URL}showcase.svg`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09111f" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonical.toString()} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #07111d;
        --bg-elevated: rgba(11, 23, 38, 0.78);
        --bg-elevated-strong: rgba(12, 28, 44, 0.95);
        --panel-border: rgba(139, 176, 215, 0.18);
        --panel-shadow: 0 26px 80px rgba(0, 0, 0, 0.38);
        --text: #f3f8ff;
        --text-muted: #93a6bf;
        --accent: #7ce7d5;
        --accent-strong: #62d3ff;
        --accent-warm: #ffb36b;
        --accent-line: rgba(124, 231, 213, 0.35);
        --code-bg: rgba(6, 15, 26, 0.9);
        --max-width: 1180px;
        --font-sans:
          "Satoshi", "Avenir Next", "Segoe UI", "Helvetica Neue", sans-serif;
        --font-mono:
          "Berkeley Mono", "SFMono-Regular", "Consolas", "Liberation Mono",
          monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-width: 320px;
        font-family: var(--font-sans);
        color: var(--text);
        background:
          radial-gradient(circle at top, rgba(65, 170, 214, 0.2), transparent 32%),
          radial-gradient(circle at 85% 18%, rgba(124, 231, 213, 0.18), transparent 22%),
          linear-gradient(180deg, #08111b 0%, #07111d 38%, #050b13 100%);
        line-height: 1.5;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.028) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.028) 1px, transparent 1px);
        background-size: 72px 72px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.7), transparent);
        opacity: 0.26;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      code,
      pre {
        font-family: var(--font-mono);
      }

      code {
        font-size: 0.95em;
      }

      .page-shell {
        position: relative;
        isolation: isolate;
      }

      .container {
        width: min(calc(100% - 2rem), var(--max-width));
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(18px);
        background: rgba(7, 17, 29, 0.72);
        border-bottom: 1px solid rgba(147, 166, 191, 0.12);
      }

      .site-header__inner,
      .site-footer__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .site-header__inner {
        min-height: 4.75rem;
      }

      .site-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.04em;
      }

      .site-brand__mark {
        width: 2.25rem;
        height: 2.25rem;
        display: grid;
        place-items: center;
        border-radius: 0.7rem;
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--accent);
        background:
          linear-gradient(145deg, rgba(98, 211, 255, 0.22), rgba(124, 231, 213, 0.08)),
          rgba(10, 21, 34, 0.95);
        border: 1px solid rgba(124, 231, 213, 0.22);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
      }

      .site-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 1rem 1.4rem;
      }

      .site-nav a,
      .site-footer a {
        color: var(--text-muted);
        transition: color 180ms ease;
      }

      .site-nav a:hover,
      .site-footer a:hover {
        color: var(--text);
      }

      main {
        padding: 2.25rem 0 5rem;
      }

      section {
        margin-top: 1.5rem;
      }

      .site-footer {
        padding: 2rem 0 3rem;
      }

      .site-footer__inner {
        padding-top: 1.5rem;
        border-top: 1px solid rgba(147, 166, 191, 0.12);
      }

      .site-footer__copy {
        color: var(--text-muted);
        font-size: 0.94rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.38rem 0.72rem;
        border: 1px solid rgba(124, 231, 213, 0.18);
        border-radius: 999px;
        font-size: 0.82rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        background: rgba(8, 19, 31, 0.72);
      }

      .eyebrow::before {
        content: "";
        width: 0.4rem;
        height: 0.4rem;
        border-radius: 999px;
        background: linear-gradient(180deg, var(--accent), var(--accent-strong));
        box-shadow: 0 0 16px rgba(124, 231, 213, 0.55);
      }

      .section-heading {
        margin: 0 0 1rem;
        font-size: clamp(1.9rem, 3vw, 3rem);
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .section-copy {
        margin: 0;
        max-width: 44rem;
        color: var(--text-muted);
        font-size: 1.02rem;
      }

      .card {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(14, 28, 44, 0.92), rgba(9, 19, 32, 0.88));
        border: 1px solid var(--panel-border);
        border-radius: 1.45rem;
        box-shadow: var(--panel-shadow);
      }

      .card::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(120deg, rgba(124, 231, 213, 0.08), transparent 34%),
          radial-gradient(circle at top right, rgba(98, 211, 255, 0.18), transparent 28%);
        pointer-events: none;
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3.25rem;
        padding: 0.85rem 1.2rem;
        border-radius: 999px;
        border: 1px solid transparent;
        font-weight: 700;
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          border-color 180ms ease,
          background 180ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button--primary {
        color: #04101a;
        background: linear-gradient(135deg, var(--accent), var(--accent-strong));
        box-shadow: 0 16px 34px rgba(98, 211, 255, 0.22);
      }

      .button--secondary {
        color: var(--text);
        border-color: rgba(147, 166, 191, 0.2);
        background: rgba(9, 18, 32, 0.72);
      }

      .button--ghost {
        color: var(--text-muted);
        border-color: rgba(147, 166, 191, 0.14);
        background: rgba(9, 18, 32, 0.26);
      }

      .kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent-warm);
        font-size: 0.88rem;
        font-family: var(--font-mono);
      }

      .kicker::before {
        content: "$";
        color: var(--accent);
      }

      .mono-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.55rem 0.82rem;
        border-radius: 999px;
        border: 1px solid rgba(147, 166, 191, 0.16);
        background: rgba(5, 12, 21, 0.64);
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--text-muted);
      }

      @media (max-width: 900px) {
        .site-header__inner,
        .site-footer__inner {
          flex-direction: column;
          align-items: flex-start;
        }

        .site-nav {
          justify-content: flex-start;
        }
      }

      @media (max-width: 640px) {
        main {
          padding-top: 1.5rem;
        }

        .container {
          width: min(calc(100% - 1.25rem), var(--max-width));
        }

        .section-heading {
          line-height: 1.08;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="container site-header__inner">
          <a class="site-brand" href="#top" aria-label="llm-tokei home">
            <span class="site-brand__mark">lt</span>
            <span>llm-tokei</span>
          </a>
          <nav class="site-nav" aria-label="Primary">
            <a href="#features">Features</a>
            <a href="#sources">Sources</a>
            <a href="#examples">Examples</a>
            <a href="https://github.com/agentic-rs/llm-tokei">GitHub</a>
            <a href="https://docs.rs/llm-tokei">docs.rs</a>
          </nav>
        </div>
      </header>
      <main id="top">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container site-footer__inner">
          <p class="site-footer__copy">
            Token usage visibility for coding agents, built for local-first workflows.
          </p>
          <nav class="site-nav" aria-label="Footer">
            <a href="https://github.com/agentic-rs/llm-tokei">GitHub</a>
            <a href="https://crates.io/crates/llm-tokei">crates.io</a>
            <a href="https://docs.rs/llm-tokei">docs.rs</a>
            <a href="https://github.com/agentic-rs/llm-tokei/blob/main/docs/usage.md">Usage guide</a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
