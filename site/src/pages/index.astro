---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "llm-tokei | Token reports for local agent sessions";
const pageDescription =
  "A Rust CLI for local coding-agent token and cost reports.";

const sourceRows = [
  ["Codex CLI", "$CODEX_HOME/sessions", "session JSONL"],
  ["OpenCode", "$OPENCODE_DATA_DIR/opencode.db", "read-only SQLite"],
  ["Claude Code", "$CLAUDE_HOME/projects", "project logs"],
  ["Copilot Chat", "editor workspaceStorage", "chat sessions"],
  ["Copilot CLI", "~/.copilot/session-state", "event logs"],
  ["Pi Agent", "~/.pi/agent/sessions", "session JSONL"]
];

const metrics = [
  ["Input", "prompt and cache tokens"],
  ["Output", "assistant tokens"],
  ["Reasoning", "reasoning tokens when available"],
  ["Cost", "mixed, official, and provider splits"],
  ["Sessions", "distinct local histories"]
];

const recipes = [
  {
    label: "Month by provider",
    command: "llm-tokei --cost-per provider --cost official --month -h"
  },
  {
    label: "Project last day",
    command: "llm-tokei --24h --group-by project,source,model"
  },
  {
    label: "Expensive sessions",
    command: "llm-tokei --7d --group-by session,source,model --sort cost --limit 10"
  },
  {
    label: "Automation JSON",
    command: "llm-tokei --7d --format json --group-by source,model,project"
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="container page">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__copy">
        <span class="eyebrow">Local token reports</span>
        <h1 id="hero-title">llm-tokei</h1>
        <p class="hero__lede">
          Turn local agent sessions into clear token, cache, and cost reports.
        </p>
        <div class="install-line" aria-label="Install command">
          <span class="install-line__prompt">$</span>
          <code>cargo install llm-tokei</code>
        </div>
        <div class="button-row">
          <a class="button button--primary" href="https://crates.io/crates/llm-tokei">
            Install
          </a>
          <a class="button button--secondary" href="https://github.com/agentic-rs/llm-tokei">
            GitHub
          </a>
          <a
            class="button button--quiet"
            href="https://github.com/agentic-rs/llm-tokei/blob/main/docs/usage.md"
          >
            Usage
          </a>
        </div>
      </div>

      <div class="hero__visual" aria-label="Example llm-tokei report">
        <div class="report-frame">
          <img
            src={`${import.meta.env.BASE_URL}showcase.svg`}
            alt="Terminal table generated by llm-tokei with token totals and cost columns"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <section id="why" class="split-section">
      <div>
        <span class="eyebrow">Why</span>
        <h2 class="section-title">One report for many agents.</h2>
      </div>
      <div class="explain-stack">
        <p class="section-copy">
          Usage is scattered across IDE chats, terminal sessions, databases,
          model names, and pricing tables. <code>llm-tokei</code> makes it one
          local report.
        </p>
        <div class="proof-grid" aria-label="Report capabilities">
          <div class="proof-item">
            <strong>Default view</strong>
            <span>source x model, sorted by total</span>
          </div>
          <div class="proof-item">
            <strong>Time windows</strong>
            <span>24h, 7d, month, or exact dates</span>
          </div>
          <div class="proof-item">
            <strong>Scriptable output</strong>
            <span>tables for people, JSON for scripts</span>
          </div>
          <div class="proof-item">
            <strong>Session dumps</strong>
            <span>Codex and Copilot JSONL</span>
          </div>
        </div>
      </div>
    </section>

    <section id="sources" class="source-section">
      <div class="source-section__header">
        <span class="eyebrow">Sources</span>
        <h2 class="section-title">Reads the usual local files.</h2>
      </div>
      <div class="source-table panel">
        <div class="source-table__row source-table__row--head">
          <span>Agent</span>
          <span>Default location</span>
          <span>Artifact</span>
        </div>
        {
          sourceRows.map(([agent, location, artifact]) => (
            <div class="source-table__row">
              <strong>{agent}</strong>
              <code>{location}</code>
              <span>{artifact}</span>
            </div>
          ))
        }
      </div>
    </section>

    <section class="metrics-section" aria-labelledby="metrics-title">
      <div class="metrics-section__copy">
        <span class="eyebrow">Counts</span>
        <h2 id="metrics-title" class="section-title">The useful columns.</h2>
      </div>
      <div class="metric-list">
        {
          metrics.map(([name, description]) => (
            <article class="metric panel">
              <h3>{name}</h3>
              <p>{description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="recipes" class="recipes-section">
      <div class="recipes-section__header">
        <span class="eyebrow">Commands</span>
        <h2 class="section-title">Start here.</h2>
      </div>
      <div class="recipe-grid">
        {
          recipes.map((recipe) => (
            <article class="recipe panel">
              <p>{recipe.label}</p>
              <pre><code>{recipe.command}</code></pre>
            </article>
          ))
        }
      </div>
    </section>

    <section class="closing panel">
      <div>
        <span class="eyebrow">Local</span>
        <h2>History stays on your machine.</h2>
      </div>
      <p>
        <code>llm-tokei</code> reads local artifacts and opens OpenCode data
        read-only. No provider history API required.
      </p>
      <div class="button-row">
        <a class="button button--primary" href="https://docs.rs/llm-tokei">
          API docs
        </a>
        <a
          class="button button--secondary"
          href="https://github.com/agentic-rs/llm-tokei/blob/main/README.md"
        >
          README
        </a>
      </div>
    </section>
  </div>

  <style>
    .page {
      display: grid;
      gap: 5rem;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      padding: 1.2rem 0 0.5rem;
      gap: 2rem;
      align-items: center;
    }

    .hero__copy {
      display: grid;
      gap: 1.35rem;
      align-content: center;
    }

    .hero h1 {
      margin: 0;
      font-size: clamp(4.4rem, 9vw, 7.6rem);
      line-height: 0.88;
      letter-spacing: 0;
    }

    .hero__lede {
      margin: 0;
      max-width: 39rem;
      color: var(--ink-soft);
      font-size: clamp(1.15rem, 2vw, 1.55rem);
      line-height: 1.32;
    }

    .install-line {
      display: flex;
      align-items: center;
      width: min(100%, 28rem);
      gap: 0.65rem;
      padding: 0.85rem 1rem;
      border: 1px solid var(--ink);
      border-radius: 8px;
      color: #f0f6f0;
      background: var(--code);
      box-shadow: 6px 6px 0 var(--line-strong);
      overflow-x: auto;
    }

    .install-line__prompt {
      color: #8ecdbb;
      font-family: var(--font-mono);
      font-weight: 800;
    }

    .hero__visual {
      min-width: 0;
    }

    .report-frame {
      border: 1px solid var(--ink);
      border-radius: 8px;
      background: var(--code);
      box-shadow: 12px 12px 0 #cfc0a6;
      overflow: hidden;
    }

    .report-frame img {
      width: 100%;
      background: var(--code);
    }

    .split-section,
    .source-section,
    .metrics-section,
    .recipes-section,
    .closing {
      display: grid;
      gap: 1.5rem;
    }

    .split-section {
      grid-template-columns: minmax(0, 0.74fr) minmax(0, 1.26fr);
      align-items: start;
      padding-top: 1rem;
    }

    .explain-stack {
      display: grid;
      gap: 1.5rem;
    }

    .proof-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--line-strong);
      border-radius: 8px;
      background: var(--line-strong);
      overflow: hidden;
    }

    .proof-item {
      display: grid;
      gap: 0.25rem;
      min-height: 8rem;
      padding: 1rem;
      background: var(--panel);
    }

    .proof-item strong {
      font-size: 1.05rem;
    }

    .proof-item span {
      color: var(--ink-soft);
    }

    .source-section__header,
    .recipes-section__header,
    .metrics-section__copy {
      display: grid;
      gap: 0.8rem;
    }

    .source-table {
      overflow: hidden;
      background: var(--panel-cool);
    }

    .source-table__row {
      display: grid;
      grid-template-columns: 0.7fr 1.5fr 0.75fr;
      gap: 1rem;
      align-items: center;
      padding: 0.95rem 1rem;
      border-top: 1px solid var(--line);
    }

    .source-table__row:first-child {
      border-top: 0;
    }

    .source-table__row--head {
      color: var(--green-deep);
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: #dde9e0;
    }

    .source-table code {
      color: var(--blue);
      word-break: break-word;
    }

    .metrics-section {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: start;
    }

    .metric-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .metric {
      padding: 1rem;
    }

    .metric h3 {
      margin: 0 0 0.4rem;
      font-size: 1.2rem;
    }

    .metric p,
    .recipe p,
    .closing p {
      margin: 0;
      color: var(--ink-soft);
    }

    .metric:nth-child(3) {
      background: #fff4df;
    }

    .metric:nth-child(4) {
      background: #f1f5ff;
    }

    .metric:nth-child(5) {
      grid-column: 1 / -1;
      background: #f5eee9;
    }

    .recipe-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.9rem;
    }

    .recipe {
      padding: 1rem;
      background: #11161b;
    }

    .recipe p {
      color: #a9b7c4;
      font-size: 0.9rem;
    }

    .recipe pre {
      margin: 0.7rem 0 0;
      overflow-x: auto;
      color: #f0f6f0;
      font-size: 0.9rem;
      line-height: 1.55;
    }

    .closing {
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr) auto;
      align-items: center;
      padding: 1.25rem;
      background: #efe6d6;
    }

    .closing h2 {
      margin: 0.45rem 0 0;
      font-size: clamp(1.7rem, 3vw, 2.8rem);
      line-height: 1;
      letter-spacing: 0;
    }

    @media (max-width: 980px) {
      .page {
        gap: 4rem;
      }

      .hero,
      .split-section,
      .metrics-section,
      .closing {
        grid-template-columns: 1fr;
      }

      .hero {
        padding-top: 0;
        align-items: start;
      }

      .hero__copy {
        order: 1;
      }

      .hero__visual {
        order: 2;
      }

      .closing {
        align-items: start;
      }
    }

    @media (max-width: 720px) {
      .proof-grid,
      .metric-list,
      .recipe-grid {
        grid-template-columns: 1fr;
      }

      .metric:nth-child(5) {
        grid-column: auto;
      }

      .source-table__row {
        grid-template-columns: 1fr;
        gap: 0.3rem;
      }

      .source-table__row--head {
        display: none;
      }

      .report-frame {
        box-shadow: 6px 6px 0 #cfc0a6;
      }
    }
  </style>
</BaseLayout>
